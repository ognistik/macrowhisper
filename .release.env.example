# Copy this file to .release.env and fill in the values for this Mac.
# Keep .release.env in .git/info/exclude. The notary profile stores its
# credentials in Keychain; do not put an Apple ID password in this file.

export DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (TEAMID)"
export NOTARYTOOL_PROFILE="notarytool-profile"

# Optional. The release script finds the sibling formula repository by default.
# export HOMEBREW_FORMULA="/absolute/path/to/homebrew-formulae/macrowhisper.rb"
